#!/bin/bash

set -euo pipefail

# ============================================
# CONFIG
# ============================================

COMMAND="${1:-}"
USERNAME="${2:-}"
ARG="${3:-}"

WG_IF="wg0"
WG_CONF="/etc/wireguard/${WG_IF}.conf"

BASE_DIR="/home/wireguard"
CLIENT_DIR="$BASE_DIR/clients"
KEY_DIR="$BASE_DIR/keys"
LOG_FILE="$BASE_DIR/users.txt"
TAG_DIR="$BASE_DIR/tags"

SCRIPT_PATH="$(readlink -f "$0")"
INSTALL_PATH="/usr/local/bin/vpn"

ACL_CHAIN="WG_ACCESS"

# ============================================
# STATE
# ============================================

is_initialized() {
    [[ -f "$WG_CONF" && -d "$BASE_DIR" ]]
}

require_init() {
    if ! is_initialized; then
        echo "Error: VPN not initialized"
        echo "Run: ./vpn init or ./vpn start"
        exit 1
    fi
}

# ============================================
# GUIDE
# ============================================

show_guide() {

    if ! is_initialized; then
cat <<EOF
==================================================
VPN SETUP GUIDE
==================================================

1. Initialize system:
   ./vpn init

2. Install CLI globally:
   ./vpn start

3. Show this guide:
   ./vpn guide

--------------------------------------------------
Run init or start before using other commands
==================================================
EOF
        return
    fi

cat <<EOF
==================================================
VPN USER MANAGER
==================================================

Usage: vpn [add|remove|list|tag|explain|guide]

1. Add user:
   vpn add <username> <target>

   full
   192.168.0.10
   192.168.0.10,192.168.0.11
   example/db
   example/

--------------------------------------------------

2. Remove user:
   vpn remove <username>

3. List users:
   vpn list

--------------------------------------------------

4. Tag:
   vpn tag add <ip> <tag>
   vpn tag remove <tag>

--------------------------------------------------

5. Explain:
   vpn explain <user|tag|directory/>

==================================================
EOF
}

# ============================================
# INSTALL
# ============================================

install_script_only() {

    if is_initialized; then
        echo "Error: already initialized"
        exit 1
    fi

    if [[ -f "$INSTALL_PATH" ]]; then
        echo "Already installed"
        exit 1
    fi

    echo "Installing → $INSTALL_PATH"
    sudo cp "$SCRIPT_PATH" "$INSTALL_PATH"
    sudo chmod +x "$INSTALL_PATH"
}

# ============================================
# INIT
# ============================================

init_full() {

    if is_initialized; then
        echo "Error: already initialized"
        exit 1
    fi

    sudo apt update
    sudo apt install -y wireguard wireguard-tools curl iptables ipset iptables-persistent

    sudo mkdir -p "$CLIENT_DIR" "$KEY_DIR" "$TAG_DIR"
    sudo touch "$LOG_FILE"

    install_script_only

    echo "Init complete"
}

# ============================================
# IPSET
# ============================================

ensure_ipset() { sudo ipset create "$1" hash:ip 2>/dev/null || true; }
flush_ipset()  { sudo ipset flush "$1" 2>/dev/null || true; }
add_ipset_ip() { sudo ipset add "$1" "$2" 2>/dev/null || true; }

# ============================================
# TAG
# ============================================

tag_add() {
    local ip="$USERNAME"
    local name="$ARG"

    [[ -z "$ip" || -z "$name" ]] && {
        echo "Usage: vpn tag add <ip> <tag>"
        exit 1
    }

    local file="$TAG_DIR/$name"
    mkdir -p "$(dirname "$file")"

    echo "$ip" > "$file"
    echo "Tag added → $name ($ip)"
}

tag_remove() {
    local name="$USERNAME"

    [[ -z "$name" ]] && {
        echo "Usage: vpn tag remove <tag>"
        exit 1
    }

    rm -f "$TAG_DIR/$name"
    echo "Tag removed → $name"
}

# ============================================
# VALIDATION
# ============================================

validate_target() {

    local input="$1"

    [[ "$input" == "full" ]] && return

    IFS=',' read -ra arr <<< "$input"

    for item in "${arr[@]}"; do

        # IP
        if [[ "$item" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            continue
        fi

        # directory
        if [[ "$item" == */ ]]; then
            [[ ! -d "$TAG_DIR/$item" ]] && {
                echo "Error: directory not found → $item"
                exit 1
            }
            continue
        fi

        # tag
        [[ ! -f "$TAG_DIR/$item" ]] && {
            echo "Error: tag not found → $item"
            exit 1
        }
    done
}

# ============================================
# RESOLVE
# ============================================

resolve_ips() {

    local input="$1"

    [[ "$input" == "full" ]] && {
        echo "FULL"
        return
    }

    local result=()

    IFS=',' read -ra arr <<< "$input"

    for item in "${arr[@]}"; do

        if [[ "$item" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            result+=("$item")
            continue
        fi

        if [[ "$item" == */ ]]; then
            for f in "$TAG_DIR/$item"*; do
                result+=("$(cat "$f")")
            done
            continue
        fi

        result+=("$(cat "$TAG_DIR/$item")")
    done

    printf "%s\n" "${result[@]}" | sort -u
}

# ============================================
# ACL
# ============================================

ensure_acl_chain() {
    sudo iptables -N "$ACL_CHAIN" 2>/dev/null || true
    sudo iptables -C FORWARD -i "$WG_IF" -j "$ACL_CHAIN" 2>/dev/null || \
        sudo iptables -A FORWARD -i "$WG_IF" -j "$ACL_CHAIN"
}

clear_acl_rules() {
    local src_ip="$1"
    sudo iptables -S "$ACL_CHAIN" | grep "$src_ip" | while read -r rule; do
        sudo iptables ${rule/-A/-D}
    done || true
}

add_acl_rules() {

    local src_ip="$1"
    local input="$2"

    ensure_acl_chain
    clear_acl_rules "$src_ip"

    if [[ "$input" == "full" ]]; then
        sudo iptables -A "$ACL_CHAIN" -s "$src_ip"/32 -d 192.168.219.0/24 -j ACCEPT
    else
        local setname="user_${src_ip//./_}"

        ensure_ipset "$setname"
        flush_ipset "$setname"

        resolve_ips "$input" | while read -r ip; do
            add_ipset_ip "$setname" "$ip"
        done

        sudo iptables -A "$ACL_CHAIN" -s "$src_ip"/32 \
            -m set --match-set "$setname" dst -j ACCEPT
    fi

    sudo iptables -A "$ACL_CHAIN" -s "$src_ip"/32 -j DROP
}

# ============================================
# IP ALLOCATION
# ============================================

next_ip() {

    local used
    used=$(awk -F'|' '{print $2}' "$LOG_FILE" 2>/dev/null | tr -d ' ')

    for i in $(seq 2 254); do
        local ip="10.0.0.$i"
        if ! grep -q "$ip" <<< "$used"; then
            echo "$ip"
            return
        fi
    done

    echo "Error: no available IP"
    exit 1
}

# ============================================
# USER
# ============================================

add_user() {

    require_init

    [[ -z "$USERNAME" || -z "$ARG" ]] && {
        echo "Usage: vpn add <username> <target>"
        exit 1
    }

    validate_target "$ARG"

    if grep -q "^$USERNAME |" "$LOG_FILE" 2>/dev/null; then
        echo "Error: user already exists"
        exit 1
    fi

    local ip
    ip=$(next_ip)

    local priv pub
    priv=$(wg genkey)
    pub=$(echo "$priv" | wg pubkey)

    echo "$priv" > "$KEY_DIR/${USERNAME}_privatekey"
    echo "$pub"  > "$KEY_DIR/${USERNAME}_publickey"

    cat <<EOF | sudo tee -a "$WG_CONF" >/dev/null

# ===== $USERNAME =====
[Peer]
PublicKey = $pub
AllowedIPs = $ip/32
EOF

    echo "$USERNAME | $ip | $ARG | $(date)" >> "$LOG_FILE"

    add_acl_rules "$ip" "$ARG"

    wg set "$WG_IF" peer "$pub" allowed-ips "$ip/32"

    echo "User added → $USERNAME ($ip)"
}

remove_user() {

    require_init

    local pub_file="$KEY_DIR/${USERNAME}_publickey"

    [[ ! -f "$pub_file" ]] && {
        echo "Error: user not found"
        exit 1
    }

    local pub
    pub=$(cat "$pub_file")

    wg set "$WG_IF" peer "$pub" remove || true

    rm -f "$KEY_DIR/${USERNAME}_"*
    sed -i "/^$USERNAME |/d" "$LOG_FILE"

    echo "User removed → $USERNAME"
}

list_users() {
    require_init
    cat "$LOG_FILE"
}

# ============================================
# EXPLAIN
# ============================================

explain() {

    require_init

    local target="$USERNAME"

    echo "===================================="

    # user
    if grep -q "^$target |" "$LOG_FILE" 2>/dev/null; then
        local rule
        rule=$(grep "^$target |" "$LOG_FILE" | awk -F'|' '{print $3}')

        echo "User: $target"
        resolve_ips "$rule"
        return
    fi

    # directory
    if [[ "$target" == */ ]]; then
        local dir="$TAG_DIR/$target"

        [[ ! -d "$dir" ]] && {
            echo "Error: directory not found"
            exit 1
        }

        find "$dir" -type f | sed "s|$TAG_DIR/||"
        return
    fi

    # tag
    local file="$TAG_DIR/$target"

    [[ ! -f "$file" ]] && {
        echo "Error: tag not found"
        exit 1
    }

    echo "Tag: $target → $(cat "$file")"
}

# ============================================
# MAIN
# ============================================

case "$COMMAND" in
    init) init_full ;;
    start) install_script_only ;;
    guide|"") show_guide ;;

    add) add_user ;;
    remove) remove_user ;;
    list) list_users ;;
    explain) explain ;;

    tag)
        case "$USERNAME" in
            add) tag_add ;;
            remove) tag_remove ;;
            *) echo "Usage: vpn tag [add|remove]" ;;
        esac
        ;;
    *)
        echo "Usage: vpn [init|start|add|remove|list|tag|guide|explain]"
        ;;
esac